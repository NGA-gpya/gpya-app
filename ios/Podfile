# GPYA iOS Podfile
# The following has been generated by Flutter.
# Do not edit this file unless you know what you are doing.

# Cargamos los helpers de Flutter si existen
helpers_path = File.expand_path(File.join('Flutter', 'generated_pod_helpers.rb'), __dir__)
if File.exist?(helpers_path)
  load helpers_path
else
  # Fallback si el archivo no existe aún (común en entornos CI/CD antes del primer pub get)
  puts "Advertencia: generated_pod_helpers.rb no encontrado. Continuando sin helpers..."
end

platform :ios, '13.0'

# CocoaPods analytics
install! 'cocoapods', :deterministic_uuids => false

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  if respond_to?(:flutter_install_all_ios_pods)
    flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  end
  
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    if respond_to?(:flutter_additional_ios_build_settings)
      flutter_additional_ios_build_settings(target)
    end
    target.build_configurations.each do |config|
      # Forzamos iOS 13.0 en todos los niveles
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
    end
  end
end
